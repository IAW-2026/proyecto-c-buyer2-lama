generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Comprador {
  id                 String   @id @default(cuid())
  clerkUserId        String   @unique
  email              String   @unique
  nombreComprador    String
  dni                String?
  telefono           String?
  direccionEnvio     String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  preferencias       PreferenciaComprador?
}

model PreferenciaComprador {
  id                    String   @id @default(cuid())
  compradorId           String   @unique
  comprador             Comprador @relation(fields: [compradorId], references: [id], onDelete: Cascade)
  tallesPreferidos      String[]
  categoriasPreferidas  String[]
  vendedoresPreferidos  String[]
}
